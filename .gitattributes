# Normalize all text files to LF in the repo regardless of OS.
* text=auto eol=lf

# Explicit overrides for clarity
*.kt          text eol=lf
*.kts         text eol=lf
*.gradle      text eol=lf
*.java        text eol=lf
*.properties  text eol=lf
*.toml        text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.md          text eol=lf
*.xml         text eol=lf
*.json        text eol=lf
*.sh          text eol=lf
gradlew       text eol=lf

# Windows-only
*.bat         text eol=crlf
*.cmd         text eol=crlf

# Binaries — never touch
*.jar         binary
*.png         binary
*.jpg         binary
*.gif         binary
*.ico         binary
*.keystore    binary
